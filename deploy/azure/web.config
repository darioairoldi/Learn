<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS configuration for serving the static Quarto site on a Windows
  Azure App Service. Copied into the deploy package (docs/web.config) by the
  azure-webapp-deploy.yml workflow.
-->
<configuration>
  <system.webServer>
    <!-- Ensure correct MIME types for assets the static site serves. -->
    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".webmanifest" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>

    <!-- Serve index.html at the site root and folder roots. -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- Use Quarto's generated 404 page for missing routes. -->
    <httpErrors errorMode="Custom" existingResponse="Replace">
      <remove statusCode="404" />
      <error statusCode="404" path="/404.html" responseMode="File" />
    </httpErrors>
  </system.webServer>
</configuration>
